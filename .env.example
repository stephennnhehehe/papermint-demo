NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server only. Never prefix these with NEXT_PUBLIC_ or commit real values.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
STRIPE_SECRET_KEY=sk_test_your-stripe-test-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Recommended for stable Stripe products. Checkout can use inline prices locally if omitted.
STRIPE_WEEKLY_PRICE_ID=price_your_aud_099_weekly_price
STRIPE_MONTHLY_PRICE_ID=price_your_aud_299_monthly_price

# Transactional document emails and daily reminders.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=PaperMint <invoices@your-verified-domain.com>
CRON_SECRET=generate-a-long-random-secret
